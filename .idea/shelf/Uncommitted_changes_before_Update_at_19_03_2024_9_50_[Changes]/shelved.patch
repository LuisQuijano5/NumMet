(\"a=\" + str(self.a))\r\n            #print(\"fa=\" + str(self.Fa))\r\n            #print(\"fb=\" + str(self.Fb))\r\n            #print(\"fxr=\" + str(self.FXr))\r\n            #print(\"flag=\" + str(self.flag))\r\n\r\n#test=Bisection_Method()\r\n#test.iteration()\r\n
